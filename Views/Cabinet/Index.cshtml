@model StudentModel

<<div class="card p-4 mx-auto my-5" style="max-width: 600px;">
    <h2 class="text-center mb-4">Личный кабинет</h2>

    <div class="text-center mb-4">
        <img src="@Model.PhotoUrl" 
             alt="@Model.FullName" 
             class="rounded-circle img-thumbnail" 
             style="width: 120px; height: 120px; object-fit: cover;" />
    </div>

    <div class="mb-3">
        <strong>ФИО:</strong> <span>@Model.FullName</span>
    </div>

    <div class="mb-3">
        <strong>Группа:</strong> <span>@Model.GroupName</span>
    </div>

    <div class="mb-4">
        <strong>Email:</strong> <span>@Model.Email</span>
    </div>

    <div class="text-center">
        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">На главную</a>
    </div>
</div>