@model AdminCabinetViewModel

@{
    ViewData["Title"] = "Панель администратора";
}

<div class="container d-flex flex-column">
    <header class="mb-3">
        <h1 class="text-start text-uppercase">Панель администратора</h1>
    </header>

    <div class="container d-flex flex-wrap gap-2">
        @foreach (var student in Model.Students)
        {
            <div class="card d-grid" style="grid-template-columns: repeat(2, 1fr); width: 400px">
                <div class="w-100 h-100 "
                     style="background-image: url(@student.PhotoUrl);
                     background-size: cover;">
                </div>
                <div class="d-flex flex-column align-items-stretch justify-content-center">
                    <span class="mb-1 text-primary">@student.Email</span>
                    <span class="mb-1">@student.FullName</span>
                    <span class="mb-1">@student.GroupName</span>
                </div>
            </div>
        }
        
        <form class="card" method="get" asp-action="AddStudent" style="width: 400px">
            <button class="btn btn-outline-primary w-100 h-100">Добавить</button>
        </form>
    </div>
</div>

